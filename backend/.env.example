# ================================
# Insurly Backend Environment Variables
# Copy this file to .env and fill in your values
# ================================

# Server
PORT=5000

# MongoDB Atlas — get from mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/insurly

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_character_secret_here

# OpenWeatherMap — free at openweathermap.org
OPENWEATHERMAP_API_KEY=your_openweathermap_key

# Google Gemini — free at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# Bhubaneswar Coordinates
BHUBANESWAR_LAT=20.2961
BHUBANESWAR_LON=85.8245

# Cron Schedule
TRIGGER_CHECK_INTERVAL=*/15 * * * *

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
